# Copy this file to config.env and edit it for your environment.

# Build variant: "ubuntu" or "debian"
# This determines which installer/automation system is used
BUILD_VARIANT="ubuntu"

# For Ubuntu autoinstall:
ISO="$HOME/Downloads/ubuntu-24.04.4-live-server-amd64.iso"
OUT="$HOME/Downloads/ubuntu-24.04.4-live-server-amd64-headless-autoinstall-status.iso"
WORK="$HOME/tmp/ubuntu-autoinstall"
ROOT="$WORK/root"

HOSTNAME="optiplex3080"
USERNAME="ubuntu"
# Generated automatically by ./setup.sh if missing.
# PASSWORD_HASH='...'

# Ubuntu-specific: If true, include a NoCloud seed for temporary installer SSH
INCLUDE_NOCLOUD_INSTALLER_CREDENTIALS="false"
LIVE_INSTALLER_HOSTNAME="ubuntu-server"
LIVE_INSTALLER_USER="installer"

# For Debian preseed:
# ISO="$HOME/Downloads/debian-12.7.0-amd64-netinst.iso"
# OUT="$HOME/Downloads/debian-12.7-autoinstall.iso"
# WORK="$HOME/tmp/debian-autoinstall"
# DEBIAN_SUITE="bookworm"
# HOSTNAME="debian-server"
# USERNAME="debian"

# Status server (optional, for monitoring installation progress)
STATUS_IP="192.168.1.23"
STATUS_PORT="8081"

# USB drive to flash, for example /dev/disk2 (macOS)
FLASH_DRIVE="/dev/disk2"
