# Copy this file to config.env and edit it.

ISO="$HOME/Downloads/ubuntu-24.04.4-live-server-amd64.iso"
OUT="$HOME/Downloads/ubuntu-24.04.4-live-server-amd64-headless-autoinstall-status.iso"
WORK="$HOME/tmp/ubuntu-autoinstall"
ROOT="$WORK/root"

HOSTNAME="optiplex3080"
USERNAME="ubuntu"
