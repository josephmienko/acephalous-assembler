# Directory configuration
WORK="$HOME/tmp/debian-autoinstall"
ROOT="$WORK/root"
OUT="$HOME/debian-autoinstall.iso"

# Build variant
BUILD_VARIANT="debian"

# Debian version
DEBIAN_SUITE="bookworm"

# System configuration
HOSTNAME="debian-server"
USERNAME="debian"
# Generated automatically by ../setup.sh if missing.
# PASSWORD_HASH='...'

# Mac running install_status_server.py
STATUS_IP="192.168.1.23"
STATUS_PORT="8081"

# USB drive to flash, for example /dev/disk2
FLASH_DRIVE="/dev/disk2"
