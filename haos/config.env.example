# Copy this file to ../config.env and edit it for your environment.
# This is the Home Assistant OS on Raspberry Pi 5 variant.

# Build variant: "haos"
BUILD_VARIANT="haos"

# Home Assistant OS image source
# If not set, will auto-download latest RPi5 image from Home Assistant GitHub releases
HA_IMAGE="${HOME}/Downloads/haos-rpi5.img.gz"
OUT="${HOME}/Downloads/haos-rpi5-headless.img"
WORK="${HOME}/tmp/haos-build"
ROOT="${WORK}/root"

# Network configuration (for headless setup)
HOSTNAME="homeassistant"
# Static IP (set to empty for DHCP)
HA_STATIC_IP="192.168.1.42"
HA_GATEWAY="192.168.1.1"
HA_NAMESERVER="8.8.8.8"
# Or use DHCP:
# HA_STATIC_IP=""

# Home Assistant onboarding pre-seed
HA_USERNAME="homeassistant"
# Generated automatically by ./setup.sh if missing.
# PASSWORD_HASH='...'

# Home Assistant location and integrations
HA_LOCATION_NAME="Home"
HA_LATITUDE="40.7128"
HA_LONGITUDE="-74.0060"
HA_ELEVATION="0"
HA_UNIT_SYSTEM="metric"  # metric or us_customary
HA_TIMEZONE="UTC"

# Optional: JSON-serialized list of integrations to pre-configure
# Example: '["mqtt", "met"]'
HA_INTEGRATIONS='[]'

# Status server (optional, for monitoring)
STATUS_IP="192.168.1.23"
STATUS_PORT="8081"

# Micro-SD card device path (for Raspberry Pi 5)
FLASH_DRIVE="/dev/disk2"  # macOS; on Linux might be /dev/sdb, /dev/sdc, etc.
